---
import type { ContactInfo, SocialNetwork } from '../data/cms';

const socialIcons: Record<SocialNetwork['platform'], string> = {
  instagram: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4.002 4.002 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  facebook: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>`,
  tiktok: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>`,
  linkedin: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  youtube: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/></svg>`,
  x: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l16 16M4 20L20 4"/></svg>`,
};

const socialLabels: Record<SocialNetwork['platform'], string> = {
  instagram: 'Instagram',
  facebook: 'Facebook',
  tiktok: 'TikTok',
  linkedin: 'LinkedIn',
  youtube: 'YouTube',
  x: 'X (Twitter)',
};

interface Props {
  contact: ContactInfo;
}

const { contact } = Astro.props;
const whatsappLink = `https://wa.me/${contact.whatsappNumber}?text=Hola,%20vengo%20desde%20la%20página%20web%20y%20me%20gustaría%20cotizar%20un%20servicio.`;
---

<footer id="contacto" class="main-footer">
  <div class="container footer-container">
    <div class="footer-brand">
      <a href="#" class="footer-logo">
        <span class="logo-bold">Xpresa</span><span class="logo-accent">T</span>
      </a>
      <p class="footer-desc">Agencia creativa que comunica ideas, potencia marcas y diseña el futuro digital.</p>
      <div class="footer-socials">
        {contact.socialNetworks?.map((s) => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={socialLabels[s.platform]} set:html={socialIcons[s.platform]} />
        ))}
      </div>
    </div>
    
    <div class="footer-links">
      <h4 class="footer-title">Navegación</h4>
      <ul class="footer-links-list">
        <li><a href="#about">Nosotros</a></li>
        <li><a href="#services">Servicios</a></li>
        <li><a href="#process">Proceso</a></li>
        <li><a href="/proyectos">Proyectos</a></li>
      </ul>
    </div>
    
    <div class="footer-contact-info">
      <h4 class="footer-title">Contacto Directo</h4>
      <ul class="footer-contact-list">
        <li>
          <a href={`tel:${contact.phone.replace(/ /g, '')}`} class="contact-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            <span>{contact.phone}</span>
          </a>
        </li>
        <li>
          <a href={`mailto:${contact.email}`} class="contact-item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>{contact.email}</span>
          </a>
        </li>
        <li>
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="contact-item highlight">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="contact-icon"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            <span>Chatear por WhatsApp</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
  
  <div class="footer-bottom">
    <div class="container footer-bottom-container">
      <p>&copy; {new Date().getFullYear()} XpresaT. Todos los derechos reservados.</p>
    </div>
  </div>

  <!-- Floating Sticky WhatsApp Button -->
  <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="whatsapp-sticky" aria-label="Escribinos por WhatsApp">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
  </a>
</footer>

<style>
  .main-footer {
    background-color: #040507;
    border-top: 1px solid var(--color-card-border);
    padding: 6rem 0 0 0;
    margin-top: 8rem;
  }

  .footer-container {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.2fr;
    gap: 4rem;
    padding-bottom: 4rem;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 800;
    margin-bottom: 1.2rem;
    display: inline-block;
  }

  .logo-bold {
    color: var(--color-text-light);
  }

  .logo-accent {
    color: var(--color-primary);
  }

  .footer-desc {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 1.8rem;
    max-width: 320px;
  }

  .footer-socials {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--color-card-border);
    background-color: var(--color-card);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    transition: var(--transition-smooth);
  }

  .social-link:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateY(-2px);
  }

  .footer-title {
    font-size: 1.1rem;
    margin-bottom: 1.8rem;
    letter-spacing: -0.01em;
  }

  .footer-links-list, .footer-contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-links-list a {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .footer-links-list a:hover {
    color: var(--color-primary);
    padding-left: 0.25rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .contact-icon {
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .contact-item:hover {
    color: var(--color-text-light);
  }

  .contact-item.highlight {
    color: var(--color-accent-red);
    font-weight: 600;
  }

  .contact-item.highlight .contact-icon {
    color: var(--color-accent-red);
  }

  .contact-item.highlight:hover {
    filter: brightness(1.2);
  }

  .footer-bottom {
    border-top: 1px solid var(--color-card-border);
    padding: 2rem 0;
    text-align: center;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.25);
  }

  /* Floating Sticky WhatsApp Button */
  .whatsapp-sticky {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    background-color: #25d366;
    color: #fff;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.3);
    z-index: 99;
    transition: var(--transition-smooth);
  }

  .whatsapp-sticky:hover {
    transform: scale(1.1) rotate(10deg);
    box-shadow: 0 6px 16px rgba(37, 211, 102, 0.4);
  }

  @media (max-width: 768px) {
    .footer-container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
  }
</style>
