---
import type { ClientBrand } from "../data/cms";

interface Props {
  clients: ClientBrand[];
}

const { clients } = Astro.props;

const doubleClients = [...clients, ...clients];
---

<section class="clients-section">
  <div class="container clients-container">
    <h3 class="clients-title" data-reveal>Marcas que Confían en Nosotros</h3>
  </div>

  <div class="logo-carousel">
    <div class="logo-track">
      {
        doubleClients.map((client) => (
          <div class="logo-item">
            {client.clientUrl ? (
              <a
                href={client.clientUrl}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`Visitar web de ${client.clientName}`}
              >
                <img
                  src={client.clientLogoLight?.url}
                  alt={client.clientName}
                  class="client-logo logo-light"
                  width="160"
                  height="60"
                  loading="lazy"
                />
                <img
                  src={client.clientLogoDark?.url}
                  alt={client.clientName}
                  class="client-logo logo-dark"
                  width="160"
                  height="60"
                  loading="lazy"
                />
              </a>
            ) : (
              <>
                <img
                  src={client.clientLogoLight?.url}
                  alt={client.clientName}
                  class="client-logo logo-light"
                  width="160"
                  height="60"
                  loading="lazy"
                />
                <img
                  src={client.clientLogoDark?.url}
                  alt={client.clientName}
                  class="client-logo logo-dark"
                  width="160"
                  height="60"
                  loading="lazy"
                />
              </>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .clients-section {
    padding: 5rem 0;
    background-color: rgba(255, 255, 255, 0.01);
    border-top: 1px solid var(--color-card-border);
    border-bottom: 1px solid var(--color-card-border);
    overflow: hidden;
  }

  .clients-container {
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .clients-title {
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-text-muted);
  }

  .logo-carousel {
    position: relative;
    width: 100%;
    mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
  }

  .logo-track {
    display: flex;
    width: max-content;
    animation: scroll 30s linear infinite;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 340px;
    height: 80px;
  }

  .client-logo {
    width: 160px;
    height: 60px;
    object-fit: contain;
    transition: var(--transition-smooth);
  }

  /* Dark mode: show light logos (white) */
  .client-logo.logo-light {
    display: block;
    filter: grayscale(1) brightness(0.85) contrast(1.2) opacity(0.4);
  }

  .client-logo.logo-dark {
    display: none;
  }

  /* Light mode: show dark logos (black) */
  :global(html.light) .client-logo.logo-light {
    display: none;
  }

  :global(html.light) .client-logo.logo-dark {
    display: block;
    filter: grayscale(1) opacity(0.35);
  }

  /* Hover: full color regardless of mode */
  .logo-item:hover .client-logo {
    filter: grayscale(0) brightness(1) contrast(1) opacity(1);
    transform: scale(1.05);
  }
</style>
