---
import type { LogoColor } from '../data/cms';

interface Props {
  isHome?: boolean;
  logoLightSrc: string;
  logoDarkSrc?: string;
  isDefaultLogo?: boolean;
  sectionColorMap?: Record<string, LogoColor>;
}

const { isHome = true, logoLightSrc, sectionColorMap = {} } = Astro.props;

const COLOR_LOGOS: Record<LogoColor, string> = {
  default: '/logos/logo-horizontal.png',
  amarillo: '/logos/logo-horizontal-amarillo.png',
  rojo: '/logos/logo-horizontal-rojo.png',
  azul: '/logos/logo-horizontal-azul.png',
  verde: '/logos/logo-horizontal-verde.png',
};

const allColors = Object.keys(COLOR_LOGOS) as LogoColor[];
---

<div class="scroll-progress" aria-hidden="true"><span class="scroll-progress-fill"></span></div>
<header class="main-header" id="navbar">
  <div class="container header-container">
    <a href="/" class="logo" transition:name="brand-logo">
      <div class="logo-wrapper">
        <!-- Light mode base logo (default state) -->
        <img src={logoLightSrc} alt="XpresaT" class="logo-light-img" />
        <!-- Color-transitioning logos — dark mode primary, light mode overlay -->
        <div class="logo-colors" id="logo-colors" data-section-colors={JSON.stringify(sectionColorMap)}>
          {allColors.map((color) => (
            <img
              src={COLOR_LOGOS[color]}
              alt={color === 'default' ? 'XpresaT' : ''}
              aria-hidden={color !== 'default' ? 'true' : undefined}
              class={`logo-color logo-color--${color}${color === 'default' ? ' is-active' : ''}`}
              data-color={color}
            />
          ))}
        </div>
      </div>
    </a>
    
    <nav class="nav-menu">
      <ul class="nav-list">
        {isHome ? (
          <li><a href="#about" class="nav-link">Nosotros</a></li>
          <li><a href="#services" class="nav-link">Servicios</a></li>
          <li><a href="#process" class="nav-link">Proceso</a></li>
          <li><a href="#contacto" class="nav-link">Contacto</a></li>
        ) : (
          <li><a href="/#about" class="nav-link">Nosotros</a></li>
          <li><a href="/#services" class="nav-link">Servicios</a></li>
          <li><a href="/#process" class="nav-link">Proceso</a></li>
          <li><a href="/#contacto" class="nav-link">Contacto</a></li>
        )}
        <li><a href="/proyectos" class="nav-link btn-projects">Proyectos</a></li>
      </ul>
    </nav>

    <div class="nav-actions">
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <!-- Moon: shown in dark mode -->
        <svg class="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <!-- Sun: shown in light mode -->
        <svg class="icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      </button>

      <button class="mobile-toggle" aria-label="Toggle Menu" aria-expanded="false">
        <span class="toggle-bar"></span>
        <span class="toggle-bar"></span>
        <span class="toggle-bar"></span>
      </button>
    </div>
  </div>
</header>

<style>
  /* Scroll progress indicator */
  .scroll-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    z-index: 1100;
    pointer-events: none;
    background: transparent;
  }

  .scroll-progress-fill {
    display: block;
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: 0 50%;
    background: linear-gradient(
      90deg,
      var(--color-accent-yellow),
      var(--color-accent-red),
      var(--color-primary)
    );
    will-change: transform;
  }

  .main-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    transition: var(--transition-smooth);
    padding: 1.5rem 0;
    padding-top: calc(1.5rem + env(safe-area-inset-top, 0px));
  }

  .main-header.scrolled {
    background-color: rgba(7, 8, 10, 0.85);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    border-bottom: 1px solid var(--color-card-border);
    padding: 1rem 0;
    padding-top: calc(1rem + env(safe-area-inset-top, 0px));
  }

  :global(html.light) .main-header.scrolled {
    background-color: rgba(242, 243, 245, 0.9);
  }

  /* Light mode + not scrolled: navbar is transparent over the dark hero, keep links light */
  :global(html.light) .main-header:not(.scrolled) .nav-link {
    color: #9ca3af;
  }

  :global(html.light) .main-header:not(.scrolled) .nav-link:hover {
    color: #f3f4f6;
  }

  :global(html.light) .main-header:not(.scrolled) .btn-projects {
    background-color: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
    color: #9ca3af;
  }

  :global(html.light) .main-header:not(.scrolled) .theme-toggle {
    border-color: rgba(255, 255, 255, 0.2);
    color: #9ca3af;
  }

  :global(html.light) .main-header:not(.scrolled) .toggle-bar {
    background-color: #f3f4f6;
  }

  /* Logo wrapper: relative container for both modes */
  .logo-wrapper {
    position: relative;
    display: inline-block;
  }

  /* Light mode base — hidden in dark mode, sizes wrapper in light mode */
  .logo-light-img {
    display: none;
    height: 52px;
    width: auto;
  }

  :global(html.light) .logo-light-img {
    display: block;
  }

  /* Color crossfade container */
  .logo-colors {
    position: relative;
    display: inline-block;
  }

  /* In light mode: overlay the color logos on top of the light base */
  :global(html.light) .logo-colors {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .logo-color {
    height: 52px;
    width: auto;
    opacity: 0;
    transition: opacity 0.6s ease;
  }

  /* Default (white) logo stays in flow to size the container in dark mode */
  .logo-color--default {
    display: block;
    position: relative;
  }

  /* In light mode: hide the white default — logo-light-img is the default */
  :global(html.light) .logo-color--default {
    display: none;
  }

  /* All color variants overlay absolutely */
  .logo-color:not(.logo-color--default) {
    position: absolute;
    top: 0;
    left: 0;
  }

  .logo-color.is-active {
    opacity: 1;
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .nav-list {
    display: flex;
    align-items: center;
    list-style: none;
    gap: 2.5rem;
  }

  .nav-link {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text-muted);
    letter-spacing: 0.02em;
    position: relative;
    padding: 0.5rem 0;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--color-primary);
    transition: var(--transition-smooth);
  }

  .nav-list li:nth-child(1) .nav-link::after { background-color: var(--color-accent-yellow); }
  .nav-list li:nth-child(2) .nav-link::after { background-color: var(--color-accent-red); }
  .nav-list li:nth-child(3) .nav-link::after { background-color: var(--color-primary); }
  .nav-list li:nth-child(4) .nav-link::after { background-color: #25d366; }

  .nav-link:hover {
    color: var(--color-text-light);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  /* Active section highlight (driven by the section IntersectionObserver) */
  .nav-link.is-current {
    color: var(--color-text-light);
  }

  .nav-link.is-current::after {
    width: 100%;
  }

  .btn-projects {
    background-color: var(--color-card);
    border: 1px solid var(--color-card-border);
    padding: 0.5rem 1.2rem;
    border-radius: 9999px;
  }

  .btn-projects:hover {
    background-color: var(--color-primary);
    border-color: var(--color-primary);
    color: var(--color-bg-dark);
  }

  .btn-projects::after {
    display: none;
  }

  /* Mobile menu toggle button */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .toggle-bar {
    width: 100%;
    height: 2px;
    background-color: var(--color-text-light);
    transition: var(--transition-smooth);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .theme-toggle {
    background: transparent;
    border: 1px solid var(--color-card-border);
    border-radius: 9999px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: var(--transition-smooth);
    padding: 0;
    flex-shrink: 0;
  }

  .theme-toggle:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .icon-sun { display: none; }
  .icon-moon { display: block; }

  :global(html.light) .icon-sun { display: block; }
  :global(html.light) .icon-moon { display: none; }

  @media (max-width: 768px) {
    .mobile-toggle {
      display: flex;
    }

    .nav-menu {
      position: absolute;
      top: 100%;
      left: 0;
      width: 100%;
      height: 0;
      overflow: hidden;
      /* No background while closed: with the default background-clip the bg
         would otherwise bleed through the transparent border and draw a 1px
         line at the header's bottom edge. */
      background-color: transparent;
      border-bottom: 1px solid transparent;
      transition: var(--transition-smooth);
    }

    .nav-menu.open {
      height: auto;
      padding: 2rem 0;
      background-color: var(--color-bg-dark);
      border-bottom: 1px solid var(--color-card-border);
    }

    .nav-list {
      flex-direction: column;
      gap: 1.5rem;
      align-items: center;
    }
  }
</style>

<script>
  import { initReveal } from '../scripts/reveal';
  import { initMagnetic } from '../scripts/magnetic';

  function setupThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    btn?.addEventListener('click', () => {
      const isLight = document.documentElement.classList.toggle('light');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
    });
  }

  function setupNavbar() {
    const navbar = document.getElementById('navbar');
    const toggle = document.querySelector('.mobile-toggle');
    const menu = document.querySelector('.nav-menu');

    // Handle scroll background toggle
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar?.classList.add('scrolled');
      } else {
        navbar?.classList.remove('scrolled');
      }
    });

    // Handle mobile menu toggle
    toggle?.addEventListener('click', () => {
      const isOpen = menu?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
      
      // Animate hamburger icon
      const bars = toggle.querySelectorAll('.toggle-bar');
      if (isOpen) {
        bars[0].setAttribute('style', 'transform: translateY(8px) rotate(45deg);');
        bars[1].setAttribute('style', 'opacity: 0;');
        bars[2].setAttribute('style', 'transform: translateY(-8px) rotate(-45deg);');
      } else {
        bars[0].setAttribute('style', '');
        bars[1].setAttribute('style', '');
        bars[2].setAttribute('style', '');
      }
    });

    // Close menu when clicking links
    const links = document.querySelectorAll('.nav-link');
    links.forEach(link => {
      link.addEventListener('click', () => {
        menu?.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
        const bars = toggle?.querySelectorAll('.toggle-bar');
        bars?.forEach(bar => bar.setAttribute('style', ''));
      });
    });

    // Scroll to top on logo click if on home page
    const logoLink = document.querySelector('.logo');
    logoLink?.addEventListener('click', (e) => {
      if (window.location.pathname === '/' && !e.ctrlKey && !e.metaKey && !e.shiftKey) {
        e.preventDefault();
        window.scrollTo({ top: 0, behavior: 'smooth' });
        history.pushState(null, '', '/');
        
        // Close mobile menu if open
        menu?.classList.remove('open');
        toggle?.setAttribute('aria-expanded', 'false');
        const bars = toggle?.querySelectorAll('.toggle-bar');
        bars?.forEach(bar => bar.setAttribute('style', ''));
      }
    });
  }

  function setupLogoColorTransition() {
    const container = document.getElementById('logo-colors');
    if (!container) return;

    const sectionColorMap: Record<string, string> = JSON.parse(
      container.dataset.sectionColors || '{}'
    );
    const logos = container.querySelectorAll<HTMLElement>('.logo-color');

    function setActiveColor(color: string) {
      logos.forEach(el => {
        el.classList.toggle('is-active', el.dataset.color === color);
      });
    }

    // Highlight the nav link matching the active section
    const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link');
    function setActiveNav(sectionId: string | null) {
      navLinks.forEach(link => {
        const href = link.getAttribute('href') || '';
        link.classList.toggle('is-current', sectionId !== null && href.endsWith(`#${sectionId}`));
      });
    }

    // Reset to default when scrolled back to hero
    window.addEventListener('scroll', () => {
      if (window.scrollY < 100) {
        setActiveColor('default');
        setActiveNav(null);
      }
    }, { passive: true });

    // Priority-based observer: handles #process being nested inside #services
    // When multiple sections intersect, the one lower in the page wins
    const sectionPriority = ['contacto', 'process', 'services', 'about'];
    const intersecting = new Set<string>();

    function updateFromIntersections() {
      for (const id of sectionPriority) {
        if (intersecting.has(id)) {
          setActiveColor(sectionColorMap[id] || 'default');
          setActiveNav(id);
          return;
        }
      }
      setActiveNav(null);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            intersecting.add(entry.target.id);
          } else {
            intersecting.delete(entry.target.id);
          }
        });
        if (window.scrollY >= 100) updateFromIntersections();
      },
      { threshold: 0.15 }
    );

    Object.keys(sectionColorMap).forEach(sectionId => {
      const el = document.getElementById(sectionId);
      if (el) observer.observe(el);
    });
  }

  // Scroll progress bar (scaleX driven by scroll position, rAF-throttled)
  let progressFill: HTMLElement | null = null;
  let progressTicking = false;

  function updateScrollProgress() {
    if (!progressFill) return;
    const doc = document.documentElement;
    const max = doc.scrollHeight - doc.clientHeight;
    const ratio = max > 0 ? Math.min(1, Math.max(0, doc.scrollTop / max)) : 0;
    progressFill.style.transform = `scaleX(${ratio})`;
  }

  function onScrollProgress() {
    if (progressTicking) return;
    progressTicking = true;
    requestAnimationFrame(() => {
      updateScrollProgress();
      progressTicking = false;
    });
  }

  function setupScrollProgress() {
    progressFill = document.querySelector<HTMLElement>('.scroll-progress-fill');
    updateScrollProgress();
  }

  // Run on page load and astro page transitions
  setupThemeToggle();
  setupNavbar();
  setupLogoColorTransition();
  setupScrollProgress();
  initReveal();
  initMagnetic();

  // Registered once (module runs once) so listeners never accumulate across navigations
  window.addEventListener('scroll', onScrollProgress, { passive: true });
  window.addEventListener('resize', onScrollProgress, { passive: true });

  document.addEventListener('astro:after-swap', () => {
    setupThemeToggle();
    setupNavbar();
    setupLogoColorTransition();
    setupScrollProgress();
  });

  document.addEventListener('astro:page-load', () => {
    initReveal();
    initMagnetic();
  });
</script>
