---
// Componente de modal interactivo Bento Grid (Client-side controller)
---

<div id="project-modal" class="modal-overlay" aria-hidden="true" role="dialog" aria-labelledby="modal-project-title">
  <div class="modal-container glass-panel">
    <button class="modal-close" aria-label="Cerrar modal">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
    
    <div class="modal-body bento-grid">
      <!-- Media Viewport (Large Video/Image) -->
      <div class="bento-video glass-panel">
        <div id="modal-primary-media" class="media-viewport"></div>
      </div>
      
      <!-- Project Information -->
      <div class="bento-info glass-panel">
        <h3 id="modal-project-title" class="modal-title"></h3>
        <div id="modal-project-desc" class="modal-description"></div>
        <a id="modal-whatsapp-cta" href="#" target="_blank" rel="noopener noreferrer" class="btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
          Consultar por este Proyecto
        </a>
      </div>
      
      <!-- Gallery / Thumbnail grid -->
      <div class="bento-gallery glass-panel">
        <h4 class="gallery-title">Galería de Contenidos</h4>
        <div id="modal-gallery-grid" class="gallery-grid"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background-color: rgba(4, 5, 7, 0.95);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    /* Exit (faster, ~70% of enter) */
    transition: opacity 0.28s var(--ease-out-quart);
  }

  .modal-overlay.open {
    opacity: 1;
    pointer-events: auto;
    /* Enter */
    transition: opacity 0.4s var(--ease-out-expo);
  }

  .modal-container {
    width: 92%;
    max-width: 1100px;
    height: 85vh;
    max-height: 750px;
    background-color: rgba(7, 8, 10, 0.9);
    border: 1px solid var(--color-card-border);
    position: relative;
    padding: 2.5rem;
    overflow: hidden;
    transform: scale(0.96);
    /* Exit (faster) */
    transition: transform 0.28s var(--ease-out-quart);
  }

  .modal-overlay.open .modal-container {
    transform: scale(1);
    /* Enter — refined ease-out-expo, no bounce */
    transition: transform 0.45s var(--ease-out-expo);
  }

  .modal-close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: transparent;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    z-index: 10;
    padding: 0.5rem;
    transition: var(--transition-smooth);
  }

  .modal-close:hover {
    color: var(--color-accent-red);
    transform: rotate(90deg);
  }

  .modal-body {
    height: 100%;
  }

  /* Sub-panels inside Bento Grid */
  .bento-video, .bento-info, .bento-gallery {
    padding: 1.5rem;
    border-radius: 12px;
  }

  /* Primary Media Viewport */
  .media-viewport {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.4);
    border-radius: 8px;
    overflow: hidden;
    position: relative;
  }

  :global(.media-viewport img), :global(.media-viewport video) {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  :global(.media-viewport iframe) {
    width: 100%;
    height: 100%;
    border: none;
    aspect-ratio: 16/9;
  }

  /* Info Panel */
  .modal-title {
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    margin-bottom: 1rem;
    line-height: 1.1;
  }

  .modal-description {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin-bottom: 2rem;
    overflow-y: auto;
    max-height: 150px;
    padding-right: 0.5rem;
  }

  /* Thumbnail Gallery */
  .gallery-title {
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
    gap: 0.75rem;
  }

  :global(.gallery-thumb) {
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid transparent;
    cursor: pointer;
    background-color: rgba(255, 255, 255, 0.02);
    transition: var(--transition-smooth);
    position: relative;
  }

  :global(.gallery-thumb img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  :global(.gallery-thumb.active) {
    border-color: var(--color-primary);
    box-shadow: 0 0 10px rgba(61, 158, 242, 0.3);
  }

  /* Play Icon overlay for video thumbnails */
  :global(.gallery-thumb.thumb-video::after) {
    content: '▶';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    color: #fff;
    background: rgba(0, 0, 0, 0.6);
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    padding-left: 2px;
  }

  @media (max-width: 900px) {
    .modal-container {
      height: 90vh;
      max-height: none;
      padding: 2rem 1.5rem;
      overflow-y: auto;
    }
    .modal-description {
      max-height: none;
      overflow-y: visible;
    }
  }
</style>

<script>
  import { animate, stagger } from 'motion';

  function setupModal() {
    const modal = document.getElementById('project-modal');
    const closeBtn = modal?.querySelector('.modal-close');
    const primaryMedia = document.getElementById('modal-primary-media');
    const titleEl = document.getElementById('modal-project-title');
    const descEl = document.getElementById('modal-project-desc');
    const ctaEl = document.getElementById('modal-whatsapp-cta');
    const galleryGrid = document.getElementById('modal-gallery-grid');
    
    let previouslyFocusedElement: HTMLElement | null = null;

    if (!modal || !primaryMedia || !titleEl || !descEl || !ctaEl || !galleryGrid || !closeBtn) return;

    // Helper to stop and clean up video elements
    function stopMedia() {
      if (primaryMedia) primaryMedia.innerHTML = '';
    }

    // Function to render the active media asset inside the viewport
    function renderActiveMedia(asset: any) {
      stopMedia();
      if (!primaryMedia) return;

      if (asset.type === 'image') {
        const img = document.createElement('img');
        img.src = asset.url;
        img.alt = asset.alt || 'Imagen de galería';
        primaryMedia.appendChild(img);
      } else if (asset.type === 'video_upload') {
        const video = document.createElement('video');
        video.src = asset.url;
        video.controls = true;
        video.autoplay = true;
        video.playsInline = true;
        primaryMedia.appendChild(video);
      } else if (asset.type === 'video_external') {
        const iframe = document.createElement('iframe');
        // Add autoplay and loop parameters safely
        const embedUrl = new URL(asset.url);
        embedUrl.searchParams.set('autoplay', '1');
        embedUrl.searchParams.set('mute', '1');
        
        iframe.src = embedUrl.toString();
        iframe.allow = 'autoplay; encrypted-media';
        iframe.setAttribute('allowfullscreen', 'true');
        primaryMedia.appendChild(iframe);
      }
    }

    // Function to open the modal
    function openModal(projectData: any) {
      previouslyFocusedElement = document.activeElement as HTMLElement;
      
      // Fill text info
      titleEl!.innerText = projectData.title;
      descEl!.innerHTML = projectData.descriptionHtml || '';
      
      // Setup customized WhatsApp CTA
      const encodedMsg = encodeURIComponent(`Hola XpresaT, me interesa saber más sobre el proyecto: ${projectData.title}`);
      ctaEl!.setAttribute('href', `https://wa.me/5216674470203?text=${encodedMsg}`);

      // Clear previous gallery
      galleryGrid!.innerHTML = '';

      // Compile all media assets (featured image + media gallery)
      const mediaAssets: any[] = [];
      
      // Add featured image as first option
      if (projectData.featuredImage) {
        mediaAssets.push({
          type: 'image',
          url: projectData.featuredImage.url,
          alt: projectData.featuredImage.alt,
          thumbUrl: projectData.featuredImage.url
        });
      }

      // Add gallery elements
      if (projectData.mediaGallery && Array.isArray(projectData.mediaGallery)) {
        projectData.mediaGallery.forEach((item: any) => {
          if (item.type === 'image' && item.image) {
            mediaAssets.push({
              type: 'image',
              url: item.image.url,
              alt: item.image.alt,
              thumbUrl: item.image.url
            });
          } else if (item.type === 'video_upload' && item.videoFile) {
            mediaAssets.push({
              type: 'video_upload',
              url: item.videoFile.url,
              alt: item.videoFile.alt,
              thumbUrl: projectData.featuredImage?.url // use featured image as placeholder
            });
          } else if (item.type === 'video_external' && item.videoUrl) {
            // Parse youtube thumbnail if possible
            let thumb = projectData.featuredImage?.url;
            mediaAssets.push({
              type: 'video_external',
              url: item.videoUrl,
              alt: 'Video de YouTube',
              thumbUrl: thumb
            });
          }
        });
      }

      // Render thumbnails and bind click events
      mediaAssets.forEach((asset, index) => {
        const thumbBtn = document.createElement('button');
        thumbBtn.className = `gallery-thumb ${asset.type !== 'image' ? 'thumb-video' : ''}`;
        thumbBtn.setAttribute('aria-label', `Ver recurso ${index + 1}`);
        
        const img = document.createElement('img');
        img.src = asset.thumbUrl;
        img.alt = '';
        thumbBtn.appendChild(img);

        thumbBtn.addEventListener('click', () => {
          // Toggle active class
          galleryGrid!.querySelectorAll('.gallery-thumb').forEach(t => t.classList.remove('active'));
          thumbBtn.classList.add('active');
          renderActiveMedia(asset);
        });

        galleryGrid!.appendChild(thumbBtn);

        // Highlight first item initially
        if (index === 0) {
          thumbBtn.classList.add('active');
        }
      });

      // Find first video to prioritize autoplay/media view, otherwise use featured image
      const firstVideoIndex = mediaAssets.findIndex(a => a.type !== 'image');
      const initialMediaIndex = firstVideoIndex !== -1 ? firstVideoIndex : 0;
      
      renderActiveMedia(mediaAssets[initialMediaIndex]);
      
      if (firstVideoIndex !== -1) {
        const thumbs = galleryGrid!.querySelectorAll('.gallery-thumb');
        thumbs.forEach(t => t.classList.remove('active'));
        thumbs[firstVideoIndex]?.classList.add('active');
      }

      // Show modal
      modal!.classList.add('open');
      modal!.setAttribute('aria-hidden', 'false');
      closeBtn!.focus();

      // Stagger the bento panels in (skip under reduced motion)
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const panels = modal!.querySelectorAll<HTMLElement>(
          '.bento-video, .bento-info, .bento-gallery'
        );
        animate(
          panels,
          { opacity: [0, 1], y: [16, 0] },
          { duration: 0.45, delay: stagger(0.08, { startDelay: 0.1 }), ease: [0.16, 1, 0.3, 1] }
        )
          .finished.then(() => {
            panels.forEach((p) => {
              p.style.removeProperty('opacity');
              p.style.removeProperty('transform');
            });
          })
          .catch(() => {});
      }

      // Prevent body scroll
      document.body.style.overflow = 'hidden';
    }

    // Function to close the modal
    function closeModal() {
      modal!.classList.remove('open');
      modal!.setAttribute('aria-hidden', 'true');
      stopMedia();
      document.body.style.overflow = '';
      
      if (previouslyFocusedElement) {
        previouslyFocusedElement.focus();
      }
    }

    // Attach click listener to project cards
    document.addEventListener('click', (e) => {
      const card = (e.target as HTMLElement).closest('.project-card');
      if (card) {
        const dataJson = card.getAttribute('data-project-data');
        if (dataJson) {
          try {
            const projectData = JSON.parse(dataJson);
            openModal(projectData);
          } catch (err) {
            console.error('Error parsing project data JSON:', err);
          }
        }
      }
    });

    // Handle keypresses on cards (accessibility Enter/Space)
    document.addEventListener('keydown', (e) => {
      const card = (e.target as HTMLElement).closest('.project-card');
      if (card && (e.key === 'Enter' || e.key === ' ')) {
        e.preventDefault();
        (card as HTMLElement).click();
      }
    });

    // Close button click
    closeBtn.addEventListener('click', closeModal);

    // Overlay click to close
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // ESC key close
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && modal.classList.contains('open')) {
        closeModal();
      }
    });

    // Accessibility Focus Trapping inside modal
    modal.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab' || !modal.classList.contains('open')) return;

      const focusableEls = modal.querySelectorAll('button, [href], input, select, textarea, [tabindex="0"]');
      const firstFocusableEl = focusableEls[0] as HTMLElement;
      const lastFocusableEl = focusableEls[focusableEls.length - 1] as HTMLElement;

      if (e.shiftKey) {
        if (document.activeElement === firstFocusableEl) {
          lastFocusableEl.focus();
          e.preventDefault();
        }
      } else {
        if (document.activeElement === lastFocusableEl) {
          firstFocusableEl.focus();
          e.preventDefault();
        }
      }
    });
  }

  // Load setup on load and transitions
  setupModal();
  document.addEventListener('astro:after-swap', setupModal);
</script>
