---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Clients from '../components/Clients.astro';
import Services from '../components/Services.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
import ProjectModal from '../components/ProjectModal.astro';
import Footer from '../components/Footer.astro';
import { getLandingPage, getProjects } from '../data/cms';
import { ClientRouter } from 'astro:transitions';


// Fetch dynamic data from the CMS (Payload v3)
const landingData = await getLandingPage();
const projects = await getProjects();

const theme = landingData.theme;
const logoVariant = theme?.logoVariant && theme.logoVariant !== 'default' ? `-${theme.logoVariant}` : '';
const logoLightSrc = theme?.logoLight?.url || `/logos/logo-horizontal${logoVariant}.png`;
const logoDarkSrc = theme?.logoDark?.url || `/logos/logo-horizontal${logoVariant}.png`;
const isDefaultLogo = !theme?.logoLight?.url && (!theme?.logoVariant || theme.logoVariant === 'default');
const sectionColorMap = {
  about: theme?.aboutLogoColor || 'amarillo',
  services: theme?.servicesLogoColor || 'rojo',
  process: theme?.processLogoColor || 'azul',
  contacto: theme?.contactLogoColor || 'verde',
};
---

<!DOCTYPE html>
<html
  lang="es"
  style={`--color-primary:${theme?.primaryColor||'#3d9ef2'};--color-accent-red:${theme?.accentColor||'#e53455'};--color-accent-yellow:${theme?.accentYellowColor||'#f8aa1f'};`}
>
<head>
  <meta charset="utf-8" />
  <script is:inline>
    (function(){var s=localStorage.getItem('theme'),d=window.matchMedia('(prefers-color-scheme: dark)').matches;if(s==='light'||(!s&&!d))document.documentElement.classList.add('light');})();
    // Add motion-ok class early if user permits motion to avoid FOUC of reveals
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.documentElement.classList.add('motion-ok');
    }
  </script>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="generator" content={Astro.generator} />

  <title>XpresaT - Agencia Creativa & Producción Audiovisual</title>
  <meta name="description" content="Agencia de marketing digital, producción audiovisual de alta calidad y desarrollo web optimizado para conversiones." />
  <ClientRouter />
</head>
<body>
  <!-- Header / Navigation -->
  <Navbar isHome={true} logoLightSrc={logoLightSrc} logoDarkSrc={logoDarkSrc} isDefaultLogo={isDefaultLogo} sectionColorMap={sectionColorMap} />

  <!-- Hero Section -->
  <Hero 
    title={landingData.hero.title}
    subtitle={landingData.hero.subtitle}
    backgroundImage={landingData.hero.backgroundImage}
    whatsappNumber={landingData.contact.whatsappNumber}
  />

  <!-- Clients Loop Logo Wall -->
  {landingData.clients && landingData.clients.length > 0 && (
    <Clients clients={landingData.clients} />
  )}

  <!-- Services & Process Sections -->
  <Services 
    services={landingData.services}
    process={landingData.process}
  />

  <!-- Featured Projects Section (Portfolio preview) -->
  {projects && projects.length > 0 && (
    <ProjectsGrid projects={projects} limit={true} />
  )}

  <!-- About Us & Team Sections -->
  <About 
    title={landingData.about.title}
    history={landingData.about.history}
    directorName={landingData.about.directorName}
    directorRole={landingData.about.directorRole}
    directorImage={landingData.about.directorImage}
    team={landingData.team}
  />

  <!-- Bento Grid Modal overlay -->
  <ProjectModal />

  <!-- Footer & Contact section -->
  <Footer contact={landingData.contact} logoLightSrc={logoLightSrc} logoDarkSrc={logoDarkSrc} isDefaultLogo={isDefaultLogo} />
</body>
</html>
