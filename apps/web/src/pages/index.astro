---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Clients from '../components/Clients.astro';
import Services from '../components/Services.astro';
import ProjectsGrid from '../components/ProjectsGrid.astro';
import ProjectModal from '../components/ProjectModal.astro';
import Footer from '../components/Footer.astro';
import { getLandingPage, getProjects } from '../data/cms';

// Fetch dynamic data from the CMS (Payload v3)
const landingData = await getLandingPage();
const projects = await getProjects();
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width" />
  <meta name="generator" content={Astro.generator} />
  
  <title>XpresaT - Agencia Creativa & Producción Audiovisual</title>
  <meta name="description" content="Agencia de marketing digital, producción audiovisual de alta calidad y desarrollo web optimizado para conversiones." />
</head>
<body>
  <!-- Header / Navigation -->
  <Navbar isHome={true} />

  <!-- Hero Section -->
  <Hero 
    title={landingData.hero.title}
    subtitle={landingData.hero.subtitle}
    backgroundImage={landingData.hero.backgroundImage}
    whatsappNumber={landingData.contact.whatsappNumber}
  />

  <!-- Clients Loop Logo Wall -->
  {landingData.clients && landingData.clients.length > 0 && (
    <Clients clients={landingData.clients} />
  )}

  <!-- Services & Process Sections -->
  <Services 
    services={landingData.services}
    process={landingData.process}
  />

  <!-- Featured Projects Section (Portfolio preview) -->
  {projects && projects.length > 0 && (
    <ProjectsGrid projects={projects} limit={true} />
  )}

  <!-- About Us & Team Sections -->
  <About 
    title={landingData.about.title}
    history={landingData.about.history}
    directorName={landingData.about.directorName}
    directorRole={landingData.about.directorRole}
    directorImage={landingData.about.directorImage}
    team={landingData.team}
  />

  <!-- Bento Grid Modal overlay -->
  <ProjectModal />

  <!-- Footer & Contact section -->
  <Footer contact={landingData.contact} />
</body>
</html>
